<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:keepScreenOn="true">

    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FF05070B"
        android:focusable="true"
        android:focusableInTouchMode="true"
        app:controller_layout_id="@layout/vod_player_control_view"
        app:show_buffering="when_playing"
        app:use_controller="false"
        app:animation_enabled="false" />

    <!-- Channel overlay - top left -->
    <LinearLayout
        android:id="@+id/channel_overlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="20dp"
        android:background="@drawable/bg_overlay_rounded"
        android:elevation="4dp"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/channel_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/brand_accent"
                android:textSize="20sp"
                android:textStyle="bold"
                tools:text="EN DIRECTO" />

            <TextView
                android:id="@+id/channel_option_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_overlay_rounded"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:textColor="#FFFFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="1 / 3" />
        </LinearLayout>

        <TextView
            android:id="@+id/channel_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#FFFFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            tools:text="DAZN LALIGA" />

        <TextView
            android:id="@+id/channel_meta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#B5FFFFFF"
            android:textSize="12sp"
            tools:text="Canal en directo" />

        <!-- Option selector list (shown when switching) -->
        <LinearLayout
            android:id="@+id/channel_options_list"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Bottom panel with action buttons -->
    <LinearLayout
        android:id="@+id/player_bottom_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_player_bottom"
        android:elevation="4dp"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="20dp">

        <!-- Current channel info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:id="@+id/bottom_now_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#FFFFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                tools:text="Channel 3" />

            <TextView
                android:id="@+id/bottom_now_meta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#99FFFFFF"
                android:textSize="14sp"
                tools:text="Group 3" />
        </LinearLayout>

        <!-- Action buttons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Guide button -->
            <LinearLayout
                android:id="@+id/btn_guide"
                style="@style/LiveActionButton"
                android:nextFocusRight="@+id/btn_history">

                <ImageButton
                    android:id="@+id/btn_guide_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="Guía TV"
                    android:focusable="false"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_live_guide" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Guía"
                    android:textColor="#CCFFFFFF"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- History button -->
            <LinearLayout
                android:id="@+id/btn_history"
                style="@style/LiveActionButton"
                android:nextFocusLeft="@+id/btn_guide"
                android:nextFocusRight="@+id/btn_favorites">

                <ImageButton
                    android:id="@+id/btn_history_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="Historial"
                    android:focusable="false"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_live_history" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Historial"
                    android:textColor="#CCFFFFFF"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Favorites button -->
            <LinearLayout
                android:id="@+id/btn_favorites"
                style="@style/LiveActionButton"
                android:nextFocusLeft="@+id/btn_history"
                android:nextFocusRight="@+id/btn_recent">

                <ImageButton
                    android:id="@+id/btn_favorites_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="Favoritos"
                    android:focusable="false"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_live_favorites" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Favoritos"
                    android:textColor="#CCFFFFFF"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Recent button -->
            <LinearLayout
                android:id="@+id/btn_recent"
                style="@style/LiveActionButton"
                android:nextFocusLeft="@+id/btn_favorites"
                android:nextFocusRight="@+id/btn_channel">

                <ImageButton
                    android:id="@+id/btn_recent_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="Recientes"
                    android:focusable="false"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_live_recent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Recientes"
                    android:textColor="#CCFFFFFF"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Channel number button -->
            <LinearLayout
                android:id="@+id/btn_channel"
                style="@style/LiveActionButton"
                android:nextFocusLeft="@+id/btn_recent"
                android:nextFocusRight="@+id/live_btn_audio">

                <ImageButton
                    android:id="@+id/btn_channel_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="Canal"
                    android:focusable="false"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_live_number" />

                <TextView
                    android:id="@+id/btn_channel_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="CH #"
                    android:textColor="#CCFFFFFF"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Spacer -->
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Audio button -->
            <ImageButton
                android:id="@+id/live_btn_audio"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_live_icon_button"
                android:contentDescription="@string/vod_audio"
                android:focusable="true"
                android:nextFocusLeft="@+id/btn_channel"
                android:nextFocusRight="@+id/live_btn_subtitles"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_vod_audio" />

            <!-- Subtitles button -->
            <ImageButton
                android:id="@+id/live_btn_subtitles"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_live_icon_button"
                android:contentDescription="@string/vod_subtitles"
                android:focusable="true"
                android:nextFocusLeft="@+id/live_btn_audio"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_vod_subtitles" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
