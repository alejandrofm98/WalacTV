<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:keepScreenOn="true">

    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FF05070B"
        android:focusable="true"
        android:focusableInTouchMode="true"
        app:controller_layout_id="@layout/vod_player_control_view"
        app:show_buffering="when_playing"
        app:use_controller="false"
        app:animation_enabled="false" />

    <!-- Channel overlay - top left (TiviMate style) -->
    <LinearLayout
        android:id="@+id/channel_overlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="24dp"
        android:background="@drawable/bg_channel_overlay"
        android:elevation="6dp"
        android:orientation="horizontal"
        android:padding="14dp">

        <!-- Channel logo -->
        <ImageView
            android:id="@+id/channel_logo"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="12dp"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_overlay_rounded"
            android:padding="4dp" />

        <!-- Channel info column -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:orientation="vertical">

            <!-- Number + option indicator row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/channel_number"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/brand_accent"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="CH 5" />

                <TextView
                    android:id="@+id/channel_option_indicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_overlay_rounded"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:textColor="#FFFFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:text="1 / 3" />
            </LinearLayout>

            <!-- Channel title -->
            <TextView
                android:id="@+id/channel_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#FFFFFFFF"
                android:textSize="17sp"
                android:textStyle="bold"
                tools:text="DAZN LALIGA" />

            <!-- Meta / event info -->
            <TextView
                android:id="@+id/channel_meta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#B5FFFFFF"
                android:textSize="12sp"
                tools:text="Real Madrid vs Barcelona" />

            <!-- Progress bar (EPG-style) -->
            <ProgressBar
                android:id="@+id/channel_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="180dp"
                android:layout_height="4dp"
                android:layout_marginTop="6dp"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/bg_progress_channel"
                android:visibility="gone" />

            <!-- Options list (shown when switching streams) -->
            <LinearLayout
                android:id="@+id/channel_options_list"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="vertical"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom panel with action buttons -->
    <LinearLayout
        android:id="@+id/player_bottom_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_player_bottom"
        android:elevation="4dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp">

        <!-- Guide button -->
        <LinearLayout
            android:id="@+id/btn_guide"
            style="@style/LiveActionButton"
            android:nextFocusRight="@+id/btn_favorites">

            <ImageButton
                android:id="@+id/btn_guide_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/live_guide"
                android:focusable="false"
                android:scaleType="centerInside"
                android:src="@drawable/ic_live_guide" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/live_guide"
                android:textColor="#CCFFFFFF"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Favorites button (star toggle) -->
        <LinearLayout
            android:id="@+id/btn_favorites"
            style="@style/LiveActionButton"
            android:nextFocusLeft="@+id/btn_guide"
            android:nextFocusRight="@+id/btn_channel">

            <ImageButton
                android:id="@+id/btn_favorites_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/live_favorites"
                android:focusable="false"
                android:scaleType="centerInside"
                android:src="@drawable/ic_favorite_border" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/live_favorites"
                android:textColor="#CCFFFFFF"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Channel stream options button (only visible for events with multiple streams) -->
        <LinearLayout
            android:id="@+id/btn_channel"
            style="@style/LiveActionButton"
            android:nextFocusLeft="@+id/btn_favorites"
            android:visibility="gone">

            <ImageButton
                android:id="@+id/btn_channel_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/live_channel"
                android:focusable="false"
                android:scaleType="centerInside"
                android:src="@drawable/ic_live_number" />

            <TextView
                android:id="@+id/btn_channel_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="CH #"
                android:textColor="#CCFFFFFF"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Error overlay container -->
    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/error_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</FrameLayout>
