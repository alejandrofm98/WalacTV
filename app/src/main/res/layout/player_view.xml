<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FF05070B"
        app:show_buffering="when_playing"
        app:use_controller="false" />

    <LinearLayout
        android:id="@+id/channel_overlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="24dp"
        android:background="#CC091018"
        android:orientation="vertical"
        android:paddingHorizontal="18dp"
        android:paddingVertical="14dp">

        <TextView
            android:id="@+id/channel_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FF28C7B7"
            android:textSize="26sp"
            android:textStyle="bold"
            tools:text="CH 7" />

        <TextView
            android:id="@+id/channel_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#FFFFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            tools:text="DAZN LALIGA" />

        <TextView
            android:id="@+id/channel_meta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#B5FFFFFF"
            android:textSize="14sp"
            tools:text="Canal en directo" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/player_bottom_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#88081018"
        android:orientation="vertical"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/bottom_now_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#FFFFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                tools:text="Channel 3" />

            <TextView
                android:id="@+id/bottom_now_meta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#C9FFFFFF"
                android:textSize="18sp"
                tools:text="Playlist 1 • Group 3" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/bottom_action_guide"
                style="@style/PlayerActionCard" />

            <TextView
                android:id="@+id/bottom_action_history"
                style="@style/PlayerActionCard" />

            <TextView
                android:id="@+id/bottom_action_one"
                style="@style/PlayerActionCard" />

            <TextView
                android:id="@+id/bottom_action_two"
                style="@style/PlayerActionCard" />

            <TextView
                android:id="@+id/bottom_action_three"
                style="@style/PlayerActionCard" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
