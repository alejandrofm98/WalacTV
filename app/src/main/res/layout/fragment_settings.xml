<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/app_background"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <LinearLayout
        android:layout_width="680dp"
        android:layout_height="wrap_content"
        android:background="#FF171D1A"
        android:orientation="vertical"
        android:padding="28dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textColor="#FFF2F4F1"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/settings_description"
            android:textColor="#FFB9C1BC"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/settings_last_update"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:textColor="#FF7BDED4"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/settings_refresh_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:backgroundTint="#FF28C7B7"
            android:text="@string/settings_refresh_button"
            android:textAllCaps="false"
            android:textColor="#FFF2F4F1"
            android:textSize="18sp" />
    </LinearLayout>
</LinearLayout>
