<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:minHeight="82dp"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="10dp">

    <TextView
        android:id="@+id/guide_channel_number"
        android:layout_width="34dp"
        android:layout_height="wrap_content"
        android:textColor="#FFF2F4F1"
        android:textSize="18sp"
        android:textStyle="bold" />

    <ImageView
        android:id="@+id/guide_channel_logo"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_marginStart="10dp"
        android:background="#FF26302B"
        android:padding="8dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_guide_tv"
        android:tint="#FF95A097" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/guide_channel_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFF2F4F1"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/guide_channel_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#FF95A097"
            android:textSize="16sp" />
    </LinearLayout>
</LinearLayout>
