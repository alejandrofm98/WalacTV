<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#FF0F1311"
                android:startColor="#FF171D1A"
                android:type="linear" />
        </shape>
    </item>

    <item android:bottom="0dp" android:right="0dp" android:top="0dp">
        <shape android:shape="rectangle">
            <stroke
                android:width="1dp"
                android:color="#2226302B" />
            <solid android:color="#00000000" />
        </shape>
    </item>
</layer-list>
